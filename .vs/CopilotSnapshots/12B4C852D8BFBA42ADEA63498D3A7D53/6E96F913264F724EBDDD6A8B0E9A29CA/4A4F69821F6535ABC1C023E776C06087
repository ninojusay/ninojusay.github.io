    // Normalize input for pattern matching
    normalizeInput(input) {
        return input.toLowerCase().trim().replace(/[^\w\s]/g, '');
    }

    // Extract keywords from input
    extractKeywords(input) {
        const normalized = this.normalizeInput(input);
        const words = normalized.split(/\s+/);
        return words;
    }

    // Detect user intent
    detectIntent(input) {
        const keywords = this.extractKeywords(input);
        let matchedIntents = [];

        for (let pattern of this.intentPatterns) {
            const hasMatch = pattern.patterns.some(p => keywords.includes(p));
            if (hasMatch) {
                matchedIntents.push({
                    intent: pattern.intent,
                    responses: pattern.responses,
                    matchCount: pattern.patterns.filter(p => keywords.includes(p)).length
                });
            }
        }

        // Return intent with highest match count
        if (matchedIntents.length > 0) {
            matchedIntents.sort((a, b) => b.matchCount - a.matchCount);
            return matchedIntents[0];
        }

        return null;
    }

    // Generate context-aware response
    generateResponse(intent, userInput) {
        if (!intent) {
            return this.generateFallbackResponse(userInput);
        }

        const responseType = intent.responses[0];
        const keywords = this.extractKeywords(userInput);

        switch (responseType) {
            case 'projects_detailed':
                return this.generateProjectResponse(keywords);

            case 'skills_detailed':
                return this.generateSkillsResponse(keywords);

            case 'hiring_response':
                this.context.interestedInHiring = true;
                return this.generateHiringResponse();

            case 'contact_info':
                return this.generateContactResponse();

            case 'tech_specific_response':
                return this.generateTechResponse(keywords);

            case 'background_response':
                return this.generateBackgroundResponse();

            case 'capstone_response':
                return this.generateCapstoneResponse();

            case 'services_response':
                return this.generateServicesResponse();

            default:
                return this.generateFallbackResponse(userInput);
        }
    }

